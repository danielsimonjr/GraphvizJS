{
  "name": "graphvizjs-desktop-client",
  "version": "2.6.0",
  "description": "Desktop editor for Graphviz DOT diagrams with real-time preview, syntax highlighting, and SVG/PNG export.",
  "license": "MIT",
  "author": {
    "name": "Daniel Simon Jr.",
    "email": "danielsimonjr@yahoo.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "bin": {
    "graphvizjs": "dist-cli/cli/index.js"
  },
  "files": [
    "dist-cli"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:cli:exe": "node scripts/build-cli-exe.mjs",
    "build:icon": "node scripts/render-icon.mjs",
    "prepack": "pnpm build:cli",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "graph": "tsx tools/dependency-graph/index.ts",
    "graph:check": "tsx tools/dependency-graph/index.ts --check",
    "docs:check": "tsx tools/docs-check/index.ts",
    "graphvizjs": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.5.3",
    "@codemirror/view": "^6.39.7",
    "@hpcc-js/wasm": "^2.22.4",
    "@resvg/resvg-js": "^2.6.2",
    "canvas": "^3.2.3",
    "codemirror": "^6.0.2",
    "electron-store": "^11.0.2",
    "jsdom": "^29.1.1",
    "jspdf": "^4.2.1",
    "remixicon": "^4.7.0",
    "svg2pdf.js": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@playwright/test": "^1.57.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.2",
    "postject": "^1.0.0-alpha.6",
    "rimraf": "^6.1.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.8"
  }
}
