{
  "name": "graphvizjs-desktop-client",
  "version": "1.1.0",
  "description": "Desktop editor for Graphviz DOT diagrams with real-time preview, syntax highlighting, and SVG/PNG export.",
  "license": "MIT",
  "author": {
    "name": "Daniel Simon Jr.",
    "email": "danielsimonjr@yahoo.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.3",
    "@codemirror/view": "^6.39.7",
    "@hpcc-js/wasm": "^2.22.4",
    "codemirror": "^6.0.2",
    "electron-store": "^11.0.2",
    "jspdf": "^4.2.1",
    "remixicon": "^4.7.0",
    "svg2pdf.js": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "happy-dom": "^20.10.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.8"
  }
}
